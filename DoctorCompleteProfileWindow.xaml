<Window x:Class="MedicalReportsApp.DoctorCompleteProfileWindow"
        xmlns="http:
        xmlns:x="http:
        Title="Complete Doctor Profile"
        Height="760"
        Width="670"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FFF3F4F6">
    <Window.Resources>
        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#FF374151"/>
        </Style>

        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="52"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#FFD1D5DB"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Foreground" Value="#FF1E293B"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="14,0,14,0" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#FF2F6FED"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputComboStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="52"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#FFD1D5DB"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="10,0,10,0"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="52"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#FF2F6FED"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="52"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#FF374151"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#FFD1D5DB"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Doctor Profile" FontSize="32" FontWeight="Bold" Foreground="#FF0F172A" HorizontalAlignment="Center" Margin="0,0,0,6"/>
            <TextBlock Text="Complete the doctor information before opening the dashboard" HorizontalAlignment="Center" FontSize="15" Foreground="#FF64748B" Margin="0,0,0,24"/>

            <Border Width="460" Background="White" CornerRadius="16" BorderBrush="#FFE5E7EB" BorderThickness="1.5" Padding="34,28,34,28">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="First Name *" Style="{StaticResource LabelText}" Margin="0,0,0,8"/>
                        <TextBox x:Name="txtFirstName" Style="{StaticResource InputTextBoxStyle}" Margin="0,0,0,18"/>

                        <TextBlock Text="Last Name *" Style="{StaticResource LabelText}" Margin="0,0,0,8"/>
                        <TextBox x:Name="txtLastName" Style="{StaticResource InputTextBoxStyle}" Margin="0,0,0,18"/>

                        <TextBlock Text="Specialization *" Style="{StaticResource LabelText}" Margin="0,0,0,8"/>
                        <TextBox x:Name="txtSpecialization" Style="{StaticResource InputTextBoxStyle}" Margin="0,0,0,18"/>

                        <TextBlock Text="Gender *" Style="{StaticResource LabelText}" Margin="0,0,0,8"/>
                        <ComboBox x:Name="cmbGender" Style="{StaticResource InputComboStyle}" Margin="0,0,0,18">
                            <ComboBoxItem Content="Male"/>
                            <ComboBoxItem Content="Female"/>
                            <ComboBoxItem Content="Other"/>
                        </ComboBox>

                        <TextBlock Text="Birth Date *" Style="{StaticResource LabelText}" Margin="0,0,0,8"/>
                        <DatePicker x:Name="dpBirthDate" Height="52" FontSize="15" Margin="0,0,0,18"/>

                        <TextBlock x:Name="txtError" Foreground="#FFDC2626" FontSize="13" TextWrapping="Wrap" Visibility="Collapsed" Margin="0,0,0,12"/>

                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" x:Name="btnSkip" Content="Skip" Style="{StaticResource SecondaryButtonStyle}" Click="btnSkip_Click"/>
                            <Button Grid.Column="2" x:Name="btnCompleteProfile" Content="Open Doctor Dashboard" Style="{StaticResource PrimaryButtonStyle}" Click="btnCompleteProfile_Click"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </StackPanel>
    </Grid>
</Window>
