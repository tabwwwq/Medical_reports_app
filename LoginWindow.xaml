<Window x:Class="MedicalReportsApp.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sign In"
        Height="760"
        Width="670"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FFF3F4F6">
    <Window.Resources>

        <!-- Rounded TextBox -->
        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="52"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#FFD1D5DB"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Foreground" Value="#FF1E293B"/>
            <Setter Property="CaretBrush" Value="#FF2F6FED"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <Grid>
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="14,0,14,0"
                                              VerticalAlignment="Center"/>
                                <TextBlock x:Name="placeholder"
                                           Text="{TemplateBinding Tag}"
                                           Margin="14,0,14,0"
                                           VerticalAlignment="Center"
                                           Foreground="#FFADB5BD"
                                           FontSize="14"
                                           IsHitTestVisible="False"
                                           Visibility="Collapsed"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="Text" Value=""/>
                                    <Condition Property="IsFocused" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="placeholder" Property="Visibility" Value="Visible"/>
                            </MultiTrigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#FF2F6FED"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Rounded PasswordBox -->
        <Style x:Key="InputPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="Height" Value="52"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#FFD1D5DB"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Foreground" Value="#FF1E293B"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="14,0,14,0"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#FF2F6FED"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Blue Sign In button -->
        <Style x:Key="SignInButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="52"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#FF2F6FED"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF2563EB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF1D4ED8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tab Active -->
        <Style x:Key="TabActiveStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#FF111827"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Margin="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tab Inactive -->
        <Style x:Key="TabInactiveStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Foreground" Value="#FF6B7280"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="Transparent"
                                CornerRadius="8"
                                Margin="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#10000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

            <TextBlock Text="Welcome Back"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="#FF0F172A"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,6"/>
            <TextBlock Text="Sign in to your account"
                       FontSize="15"
                       Foreground="#FF64748B"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,28"/>

            <Border Width="460"
                    Background="White"
                    CornerRadius="16"
                    BorderBrush="#FFE5E7EB"
                    BorderThickness="1.5"
                    Padding="34,28,34,28">
                <StackPanel>

                    <!-- Role Tab Switcher -->
                    <Border Background="#FFF3F4F6"
                            CornerRadius="12"
                            Padding="4"
                            Margin="0,0,0,24">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="btnPatientTab"
                                    Grid.Column="0"
                                    Content="Patient"
                                    Style="{StaticResource TabActiveStyle}"
                                    Click="btnPatientTab_Click"/>
                            <Button x:Name="btnDoctorTab"
                                    Grid.Column="1"
                                    Content="Doctor"
                                    Style="{StaticResource TabInactiveStyle}"
                                    Click="btnDoctorTab_Click"/>
                        </Grid>
                    </Border>

                    <!-- Email -->
                    <TextBlock Text="Email Address"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#FF374151"
                               Margin="0,0,0,8"/>
                    <TextBox x:Name="txtEmail"
                             Style="{StaticResource InputTextBoxStyle}"
                             Tag="your.email@example.com"
                             Margin="0,0,0,18"/>

                    <!-- Password -->
                    <TextBlock Text="Password"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#FF374151"
                               Margin="0,0,0,8"/>
                    <PasswordBox x:Name="txtPassword"
                                 Style="{StaticResource InputPasswordBoxStyle}"
                                 Margin="0,0,0,8"/>

                    <!-- Forgot password -->
                    <Button x:Name="btnForgotPassword"
                            Content="Forgot password?"
                            HorizontalAlignment="Right"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="#FF2563EB"
                            FontSize="13"
                            Cursor="Hand"
                            Margin="0,0,0,20"
                            Click="btnForgotPassword_Click"/>

                    <!-- Error -->
                    <TextBlock x:Name="txtError"
                               Foreground="#FFDC2626"
                               TextWrapping="Wrap"
                               Visibility="Collapsed"
                               Margin="0,0,0,12"
                               FontSize="13"/>

                    <!-- Sign In -->
                    <Button x:Name="btnSignIn"
                            Content="Sign In"
                            Style="{StaticResource SignInButtonStyle}"
                            Margin="0,0,0,20"
                            Click="btnSignIn_Click"/>

                    <Separator Background="#FFE5E7EB" Margin="0,0,0,16"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="Don't have an account? "
                                   FontSize="14"
                                   Foreground="#FF6B7280"/>
                        <Button x:Name="btnCreateAccount"
                                Content="Create Account"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="#FF2563EB"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Cursor="Hand"
                                Padding="0"
                                Click="btnCreateAccount_Click"/>
                    </StackPanel>

                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Window>
