<Window x:Class="MedicalReportsApp.LoginWindow"
        xmlns="http:
        xmlns:x="http:
        Title="Sign In"
        Height="760"
        Width="670"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FFF3F4F6">
    <Window.Resources>

        
        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="52"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#FFD1D5DB"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Foreground" Value="#FF1E293B"/>
            <Setter Property="CaretBrush" Value="#FF2F6FED"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <Grid>
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="14,0,14,0"
                                              VerticalAlignment="Center"/>
                                <TextBlock x:Name="placeholder"
                                           Text="{TemplateBinding Tag}"
                                           Margin="14,0,14,0"
                                           VerticalAlignment="Center"
                                           Foreground="#FFADB5BD"
                                           FontSize="14"
                                           IsHitTestVisible="False"
                                           Visibility="Collapsed"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="Text" Value=""/>
                                    <Condition Property="IsFocused" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="placeholder" Property="Visibility" Value="Visible"/>
                            </MultiTrigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#FF2F6FED"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        
        <Style x:Key="InputPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="Height" Value="52"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#FFD1D5DB"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Foreground" Value="#FF1E293B"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="14,0,14,0"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#FF2F6FED"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        
        <Style x:Key="SignInButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="52"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#FF2F6FED"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF2563EB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF1D4ED8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GreenButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="52"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#FF16C246"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF14B23E"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF0EA53A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TabActiveStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#FF111827"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Margin="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        
        <Style x:Key="TabInactiveStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Foreground" Value="#FF6B7280"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="Transparent"
                                CornerRadius="8"
                                Margin="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#10000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

            <TextBlock Text="Welcome Back"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="#FF0F172A"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,6"/>
            <TextBlock Text="Sign in to your account"
                       FontSize="15"
                       Foreground="#FF64748B"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,28"/>

            <Border Width="460"
                    Background="White"
                    CornerRadius="16"
                    BorderBrush="#FFE5E7EB"
                    BorderThickness="1.5"
                    Padding="34,28,34,28">
                <Grid>
                    <StackPanel x:Name="loginPanel">

                    
                    <Border Background="#FFF3F4F6"
                            CornerRadius="12"
                            Padding="4"
                            Margin="0,0,0,24">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="btnPatientTab"
                                    Grid.Column="0"
                                    Content="Patient"
                                    Style="{StaticResource TabActiveStyle}"
                                    Click="btnPatientTab_Click"/>
                            <Button x:Name="btnDoctorTab"
                                    Grid.Column="1"
                                    Content="Doctor"
                                    Style="{StaticResource TabInactiveStyle}"
                                    Click="btnDoctorTab_Click"/>
                        </Grid>
                    </Border>

                    
                    <TextBlock Text="Email Address"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#FF374151"
                               Margin="0,0,0,8"/>
                    <TextBox x:Name="txtEmail"
                             Style="{StaticResource InputTextBoxStyle}"
                             Tag="your.email@example.com"
                             Margin="0,0,0,18"/>

                    
                    <TextBlock Text="Password"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#FF374151"
                               Margin="0,0,0,8"/>
                    <PasswordBox x:Name="txtPassword"
                                 Style="{StaticResource InputPasswordBoxStyle}"
                                 Margin="0,0,0,8"/>

                    
                    <Button x:Name="btnForgotPassword"
                            Content="Forgot password?"
                            HorizontalAlignment="Right"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="#FF2563EB"
                            FontSize="13"
                            Cursor="Hand"
                            Margin="0,0,0,20"
                            Click="btnForgotPassword_Click"/>

                    
                    <TextBlock x:Name="txtError"
                               Foreground="#FFDC2626"
                               TextWrapping="Wrap"
                               Visibility="Collapsed"
                               Margin="0,0,0,12"
                               FontSize="13"/>

                    
                    <Button x:Name="btnSignIn"
                            Content="Sign In"
                            Style="{StaticResource SignInButtonStyle}"
                            Margin="0,0,0,20"
                            Click="btnSignIn_Click"/>

                    <Separator Background="#FFE5E7EB" Margin="0,0,0,16"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="Don't have an account? "
                                   FontSize="14"
                                   Foreground="#FF6B7280"/>
                        <Button x:Name="btnCreateAccount"
                                Content="Create Account"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="#FF2563EB"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Cursor="Hand"
                                Padding="0"
                                Click="btnCreateAccount_Click"/>
                    </StackPanel>

                    </StackPanel>

                    <StackPanel x:Name="resetPanel" Visibility="Collapsed">
                        <TextBlock Text="Reset Password"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="#FF0F172A"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,10"/>

                        <TextBlock x:Name="txtResetInfo"
                                   Text="Enter your email and get a code to change the password."
                                   FontSize="13"
                                   Foreground="#FF64748B"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,18"/>

                        <TextBlock Text="Email Address"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#FF374151"
                                   Margin="0,0,0,8"/>
                        <TextBox x:Name="txtResetEmail"
                                 Style="{StaticResource InputTextBoxStyle}"
                                 Tag="your.email@example.com"
                                 Margin="0,0,0,18"/>

                        <Button x:Name="btnSendResetCode"
                                Content="Send Code"
                                Style="{StaticResource SignInButtonStyle}"
                                Margin="0,0,0,18"
                                Click="btnSendResetCode_Click"/>

                        <Border x:Name="resetSuccessBorder"
                                Visibility="Collapsed"
                                Background="#FFF0FDF4"
                                BorderBrush="#FF86EFAC"
                                BorderThickness="1.5"
                                CornerRadius="12"
                                Padding="16"
                                Margin="0,0,0,18">
                            <StackPanel>
                                <TextBlock Text="Verification code sent!"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="#FF15803D"/>
                                <TextBlock x:Name="txtResetVerificationInfo"
                                           Margin="0,6,0,0"
                                           FontSize="14"
                                           Foreground="#FF166534"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <StackPanel x:Name="resetVerificationPanel" Visibility="Collapsed">
                            <TextBlock Text="Enter Verification Code *"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="#FF374151"
                                       Margin="0,0,0,8"/>
                            <TextBox x:Name="txtResetCode"
                                     Style="{StaticResource InputTextBoxStyle}"
                                     Margin="0,0,0,10"
                                     FontSize="22"
                                     FontWeight="SemiBold"
                                     HorizontalContentAlignment="Center"
                                     MaxLength="6"/>

                            <TextBlock Text="Enter the 6-digit code sent to your email"
                                       FontSize="13"
                                       Foreground="#FF64748B"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,18"/>

                            <TextBlock Text="New Password"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="#FF374151"
                                       Margin="0,0,0,8"/>
                            <PasswordBox x:Name="txtNewPassword"
                                         Style="{StaticResource InputPasswordBoxStyle}"
                                         Margin="0,0,0,18"/>

                            <TextBlock Text="Repeat New Password"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="#FF374151"
                                       Margin="0,0,0,8"/>
                            <PasswordBox x:Name="txtRepeatNewPassword"
                                         Style="{StaticResource InputPasswordBoxStyle}"
                                         Margin="0,0,0,18"/>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0"
                                        Content="Back"
                                        Style="{StaticResource SignInButtonStyle}"
                                        Background="White"
                                        Foreground="#FF111827"
                                        BorderBrush="#FFD1D5DB"
                                        Click="btnResetBack_Click"/>

                                <Button x:Name="btnChangePassword"
                                        Grid.Column="2"
                                        Content="Save"
                                        Style="{StaticResource GreenButtonStyle}"
                                        Click="btnChangePassword_Click"/>
                            </Grid>

                            <Button Content="Resend verification code"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="#FF2563EB"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Cursor="Hand"
                                    Padding="0"
                                    HorizontalAlignment="Center"
                                    Click="btnSendResetCode_Click"/>
                        </StackPanel>

                        <Button x:Name="btnBackToSignIn"
                                Content="Back to Sign In"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="#FF2563EB"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Cursor="Hand"
                                Padding="0"
                                Margin="0,8,0,0"
                                Click="btnBackToSignIn_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>
    </Grid>
</Window>
