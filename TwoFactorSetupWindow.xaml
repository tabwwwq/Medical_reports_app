<Window x:Class="MedicalReportsApp.TwoFactorSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Google Authenticator"
        Height="962"
        Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FFF3F4F6">
    <Window.Resources>
        <Style x:Key="RoundedButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="BorderBrush" Value="#2563EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryRoundedButtonStyle" TargetType="Button" BasedOn="{StaticResource RoundedButtonStyle}">
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Border Background="White" BorderBrush="#FFD1D5DB" BorderThickness="1" CornerRadius="22" Padding="28">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Connect Google Authenticator" FontSize="28" FontWeight="Bold" Foreground="#FF1F2937" TextWrapping="Wrap"/>

                <TextBlock Grid.Row="1" Margin="0,16,0,0" Text="Scan the QR code in Google Authenticator, Microsoft Authenticator, or Authy. You can also enter the secret key manually if needed." FontSize="15" Foreground="#FF4B5563" TextWrapping="Wrap"/>

                <Border Grid.Row="2" Margin="0,20,0,0" Background="#FFF9FAFB" BorderBrush="#FFE5E7EB" BorderThickness="1" CornerRadius="18" Padding="18">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Scan this QR code" FontSize="16" FontWeight="SemiBold" Foreground="#FF111827"/>

                        <Border Grid.Row="1" Width="220" Height="220" Margin="0,14,0,0" HorizontalAlignment="Center" Background="White" BorderBrush="#FFE5E7EB" BorderThickness="1" CornerRadius="16" Padding="10">
                            <Image x:Name="imgQrCode" Stretch="Uniform"/>
                        </Border>

                        <TextBlock Grid.Row="2" Margin="0,18,0,0" Text="Secret key" FontSize="15" FontWeight="SemiBold" Foreground="#FF111827"/>
                        <StackPanel Grid.Row="3" Margin="0,10,0,0">
                            <Border Background="White" BorderBrush="#FFD1D5DB" BorderThickness="1" CornerRadius="12" Padding="14,10">
                                <TextBox x:Name="txtSecretKey" IsReadOnly="True" FontSize="17" FontWeight="SemiBold" BorderThickness="0" Background="Transparent" Foreground="#FF2563EB" TextWrapping="Wrap"/>
                            </Border>
                            <TextBlock x:Name="txtAccount" Margin="0,10,0,0" FontSize="14" Foreground="#FF6B7280" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <StackPanel Grid.Row="3" Margin="0,20,0,0">
                    <TextBlock Text="Verification code" FontSize="16" FontWeight="SemiBold" Foreground="#FF111827"/>
                    <Border Margin="0,10,0,0" Background="White" BorderBrush="#FFD1D5DB" BorderThickness="1" CornerRadius="14" Padding="10,0">
                        <TextBox x:Name="txtCode" Height="58" MaxLength="6" FontSize="28" FontWeight="SemiBold" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" BorderThickness="0" Background="Transparent"/>
                    </Border>
                    <TextBlock Margin="0,8,0,0" Text="Enter the current 6-digit code from your authenticator app." FontSize="13" Foreground="#FF6B7280"/>
                </StackPanel>

                <TextBlock x:Name="txtError" Grid.Row="4" Margin="0,14,0,0" Foreground="#FFDC2626" FontSize="14" Visibility="Collapsed" TextWrapping="Wrap"/>

                <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
                    <Button Content="Cancel" Width="130" Height="48" Margin="0,0,12,0" Style="{StaticResource SecondaryRoundedButtonStyle}" Click="btnCancel_Click"/>
                    <Button Content="Enable 2FA" Width="150" Height="48" Style="{StaticResource RoundedButtonStyle}" Background="#22C55E" BorderBrush="#22C55E" Click="btnEnable_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
