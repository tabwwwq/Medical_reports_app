<Window x:Class="MedicalReportsApp.SuccessWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Success"
        Height="280"
        Width="430"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FFF3F4F6">
    <Grid>
        <Border Width="360"
                Padding="28"
                Background="White"
                CornerRadius="16"
                BorderBrush="#FFD1D5DB"
                BorderThickness="2"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">
            <StackPanel>
                <TextBlock Text="Account created successfully"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="#FF111827"
                           TextAlignment="Center"
                           Margin="0,0,0,12"/>
                <TextBlock Text="Your account was verified and saved in the database."
                           FontSize="15"
                           Foreground="#FF64748B"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Margin="0,0,0,22"/>
                <Button Content="Close"
                        Height="50"
                        FontSize="16"
                        FontWeight="Bold"
                        Background="#FF2F6FED"
                        Foreground="White"
                        BorderBrush="#FF2B63D9"
                        BorderThickness="2"
                        Click="Button_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
