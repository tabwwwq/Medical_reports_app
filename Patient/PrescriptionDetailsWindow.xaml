<Window x:Class="MedicalReportsApp.PrescriptionDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Prescription Details"
        Height="840"
        Width="1040"
        MinHeight="840"
        MinWidth="1040"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FFF3F4F6">
    <Window.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFF8FAFC"/>
            <Setter Property="BorderBrush" Value="#FFD1D5DB"/>
            <Setter Property="BorderThickness" Value="1.2"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="18"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="50"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#FF2F6FED"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="50"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#FF111827"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#FFD1D5DB"/>
            <Setter Property="BorderThickness" Value="1.2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Margin="0,0,0,22">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Prescription Details" FontSize="28" FontWeight="Bold" Foreground="#FF111827" VerticalAlignment="Center"/>
            <Button Grid.Column="1" Content="✕" Width="42" Height="42" Style="{StaticResource GhostButtonStyle}" Click="btnClose_Click"/>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Medication" FontSize="13" Foreground="#FF6B7280" Margin="0,0,0,8"/>
                        <TextBlock x:Name="txtMedication" FontSize="30" FontWeight="Bold" Foreground="#FF111827" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Dosage" FontSize="13" Foreground="#FF6B7280" Margin="0,0,0,8"/>
                            <TextBlock x:Name="txtDosage" FontSize="22" FontWeight="SemiBold" Foreground="#FF111827"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Quantity" FontSize="13" Foreground="#FF6B7280" Margin="0,0,0,8"/>
                            <TextBlock x:Name="txtQuantity" FontSize="22" FontWeight="SemiBold" Foreground="#FF111827"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Prescribed By" FontSize="13" Foreground="#FF6B7280" Margin="0,0,0,8"/>
                            <TextBlock x:Name="txtDoctor" FontSize="20" FontWeight="SemiBold" Foreground="#FF111827" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Created" FontSize="13" Foreground="#FF6B7280" Margin="0,0,0,8"/>
                            <TextBlock x:Name="txtCreatedAt" FontSize="20" FontWeight="SemiBold" Foreground="#FF111827"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Prescription ID" FontSize="13" Foreground="#FF6B7280" Margin="0,0,0,8"/>
                        <TextBlock x:Name="txtPrescriptionId" FontSize="20" FontWeight="SemiBold" Foreground="#FF111827"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Status" FontSize="13" Foreground="#FF6B7280" Margin="0,0,0,12"/>
                        <Border Background="#FFDCFCE7" BorderBrush="#FF86EFAC" BorderThickness="1" CornerRadius="8" Padding="10,6" HorizontalAlignment="Left">
                            <TextBlock x:Name="txtStatus" FontSize="15" FontWeight="SemiBold" Foreground="#FF15803D"/>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Prescription QR Code" FontSize="14" Foreground="#FF6B7280" Margin="0,0,0,18" HorizontalAlignment="Center"/>
                    <Border Background="White" BorderBrush="#FFE5E7EB" BorderThickness="1" CornerRadius="12" Padding="14" Margin="0,0,0,16">
                        <Image x:Name="imgQrCode" Width="220" Height="220" Stretch="Uniform"/>
                    </Border>
                    <TextBlock Text="QR contains name, dosage, and quantity." FontSize="13" Foreground="#FF4B5563" TextAlignment="Center" TextWrapping="Wrap" Width="220"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Margin="0,24,0,0">
            <Button Content="Close" Style="{StaticResource GhostButtonStyle}" Click="btnClose_Click" Height="52"/>
        </Grid>
    </Grid>
</Window>
