<Window x:Class="MedicalReportsApp.VisitDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Visit Details"
        Height="820"
        Width="940"
        MinHeight="720"
        MinWidth="840"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#FFF3F4F6">
    <Grid Margin="18">
        <Border Background="White" BorderBrush="#FFD1D5DB" BorderThickness="1.2" CornerRadius="18" Padding="22">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" CanContentScroll="False" PanningMode="VerticalOnly" PanningDeceleration="0.001" Padding="0,0,4,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Visit Details" FontSize="22" FontWeight="Bold" Foreground="#FF111827" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="✕" Click="btnClose_Click" Width="42" Height="42" FontSize="18" Background="Transparent" BorderThickness="0" Foreground="#FF4B5563" Cursor="Hand"/>
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,26,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="18"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="#FFF8FAFC" BorderBrush="#FFD1D5DB" BorderThickness="1.2" CornerRadius="12" Padding="16">
                            <StackPanel>
                                <TextBlock Text="Doctor" FontSize="13" FontWeight="SemiBold" Foreground="#FF6B7280" Margin="0,0,0,8"/>
                                <TextBlock x:Name="txtDoctor" FontSize="15" FontWeight="Bold" Foreground="#FF111827" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Background="#FFF8FAFC" BorderBrush="#FFD1D5DB" BorderThickness="1.2" CornerRadius="12" Padding="16">
                            <StackPanel>
                                <TextBlock Text="Date" FontSize="13" FontWeight="SemiBold" Foreground="#FF6B7280" Margin="0,0,0,8"/>
                                <TextBlock x:Name="txtDate" FontSize="15" FontWeight="Bold" Foreground="#FF111827" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Grid.Row="2" Background="#FFF8FAFC" BorderBrush="#FFD1D5DB" BorderThickness="1.2" CornerRadius="12" Padding="16" Margin="0,0,0,18">
                        <StackPanel>
                            <TextBlock Text="Reason for Visit" FontSize="13" FontWeight="SemiBold" Foreground="#FF6B7280" Margin="0,0,0,8"/>
                            <TextBlock x:Name="txtReason" FontSize="15" FontWeight="Bold" Foreground="#FF111827" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="3" Background="#FFF8FAFC" BorderBrush="#FFD1D5DB" BorderThickness="1.2" CornerRadius="12" Padding="16" Margin="0,0,0,18">
                        <StackPanel>
                            <TextBlock Text="Diagnosis" FontSize="13" FontWeight="SemiBold" Foreground="#FF6B7280" Margin="0,0,0,8"/>
                            <TextBlock x:Name="txtDiagnosis" FontSize="15" FontWeight="Bold" Foreground="#FF111827" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="4" Background="#FFF8FAFC" BorderBrush="#FFD1D5DB" BorderThickness="1.2" CornerRadius="12" Padding="16" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="Notes" FontSize="13" FontWeight="SemiBold" Foreground="#FF6B7280" Margin="0,0,0,8"/>
                            <TextBox x:Name="txtNotes"
                                     FontSize="15"
                                     FontWeight="SemiBold"
                                     Foreground="#FF111827"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     IsReadOnly="True"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     VerticalScrollBarVisibility="Disabled"
                                     HorizontalScrollBarVisibility="Disabled"
                                     MinHeight="170"
                                     Text=""/>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="5" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Content="Close" Click="btnClose_Click" Height="50" FontSize="15" FontWeight="Bold" Foreground="#FF111827" Background="White" BorderBrush="#FFD1D5DB" BorderThickness="1.2" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button Grid.Column="2" Content="Download PDF" Click="btnDownloadPdf_Click" Height="50" FontSize="15" FontWeight="Bold" Foreground="White" Background="#FF2F6FED" BorderThickness="0" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
