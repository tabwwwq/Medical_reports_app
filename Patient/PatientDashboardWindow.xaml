<Window x:Class="MedicalReportsApp.PatientDashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Patient Dashboard"
        Height="900"
        Width="1500"
        WindowStartupLocation="CenterScreen"
        Background="#FFF3F4F6">
    <Window.Resources>
        <Style x:Key="PageCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFF8FAFC"/>
            <Setter Property="BorderBrush" Value="#FFD1D5DB"/>
            <Setter Property="BorderThickness" Value="1.2"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style x:Key="SmallInfoCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFF8FAFC"/>
            <Setter Property="BorderBrush" Value="#FFD1D5DB"/>
            <Setter Property="BorderThickness" Value="1.2"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#FF111827"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#FF6B7280"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Foreground" Value="#FF111827"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="GhostButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#FF1F2937"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#FFD1D5DB"/>
            <Setter Property="BorderThickness" Value="1.2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SearchBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#FFD1D5DB"/>
            <Setter Property="BorderThickness" Value="1.2"/>
            <Setter Property="Padding" Value="14,0,14,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="12,0,12,0" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="VisitTemplate">
            <Border Style="{StaticResource SmallInfoCardStyle}" Padding="16" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="{Binding DoctorName}" FontSize="15" FontWeight="SemiBold" Foreground="#FF111827"/>
                        <TextBlock Text="{Binding VisitDate, StringFormat=yyyy-MM-dd}" FontSize="13" Foreground="#FF6B7280" Margin="0,8,0,6"/>
                        <TextBlock Text="{Binding VisitType}" FontSize="14" Foreground="#FF374151" TextWrapping="Wrap"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="View More"
                            Style="{StaticResource GhostButtonStyle}"
                            MinWidth="110"
                            Height="44"
                            Margin="16,0,0,0"
                            VerticalAlignment="Center"
                            Tag="{Binding}"
                            Click="btnViewVisitDetails_Click"/>
                </Grid>
            </Border>
        </DataTemplate>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#FF2F6FED"/>
            <Setter Property="BorderBrush" Value="#FF2F6FED"/>
            <Setter Property="MinWidth" Value="106"/>
        </Style>

        <DataTemplate x:Key="PrescriptionTemplate">
            <Border Style="{StaticResource SmallInfoCardStyle}" Padding="14" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="{Binding DisplayName}" FontSize="15" FontWeight="SemiBold" Foreground="#FF111827"/>
                        <TextBlock Text="{Binding DisplayLine}" FontSize="13" Foreground="#FF6B7280" Margin="0,6,0,0"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="👁  View"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Tag="{Binding}"
                            Margin="16,0,0,0"
                            Click="btnViewPrescription_Click"/>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,0,18,0">
            <StackPanel>
                <Border Style="{StaticResource PageCardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border x:Name="patientAvatarBorder" Width="92" Height="92" BorderBrush="#FF9CA3AF" BorderThickness="2" CornerRadius="46" HorizontalAlignment="Left" VerticalAlignment="Top" Background="#FFE5E7EB">
                            <Viewbox Stretch="Uniform">
                                <TextBlock x:Name="txtPatientAvatarIcon" Text="👤" FontSize="38" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Viewbox>
                        </Border>

                        <StackPanel Grid.Column="1">
                            <DockPanel Margin="0,0,0,12">
                                <TextBlock x:Name="txtFullName" Text="Patient" FontSize="32" FontWeight="Bold" Foreground="#FF111827" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="Edit Profile" Click="btnEditProfile_Click" Style="{StaticResource GhostButtonStyle}" Margin="0,0,10,0"/>
                                    <Button Content="Logout" Click="btnLogout_Click" Style="{StaticResource GhostButtonStyle}" HorizontalAlignment="Right"/>
                                </StackPanel>

                            </DockPanel>

                            <Grid Margin="0,4,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource SmallInfoCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Age" Style="{StaticResource LabelStyle}"/>
                                        <TextBlock x:Name="txtAge" Style="{StaticResource ValueStyle}"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" Style="{StaticResource SmallInfoCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Gender" Style="{StaticResource LabelStyle}"/>
                                        <TextBlock x:Name="txtGender" Style="{StaticResource ValueStyle}"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource SmallInfoCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Patient ID" Style="{StaticResource LabelStyle}"/>
                                        <TextBlock x:Name="txtPatientId" Style="{StaticResource ValueStyle}"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" Style="{StaticResource SmallInfoCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Blood Type" Style="{StaticResource LabelStyle}"/>
                                        <TextBlock x:Name="txtBloodType" Style="{StaticResource ValueStyle}"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Border Style="{StaticResource SmallInfoCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Email" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock x:Name="txtEmail" Style="{StaticResource ValueStyle}"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SmallInfoCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Phone" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock x:Name="txtPhone" Style="{StaticResource ValueStyle}"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SmallInfoCardStyle}" Margin="0,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="Address" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock x:Name="txtAddress" Style="{StaticResource ValueStyle}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource PageCardStyle}" Padding="22">
                        <StackPanel>
                            <TextBlock Text="My Doctor" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,6"/>
                            <TextBlock x:Name="txtDoctorName" FontSize="17" FontWeight="SemiBold" Foreground="#FF111827" Margin="0,0,0,6"/>
                            <TextBlock x:Name="txtDoctorSpecialization" FontSize="14" Foreground="#FF6B7280" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource PageCardStyle}" Padding="22">
                        <StackPanel>
                            <TextBlock Text="Prescriptions" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,6"/>
                            <TextBlock x:Name="txtPrescriptionCount" FontSize="17" FontWeight="SemiBold" Foreground="#FF111827" Margin="0,0,0,12"/>
                            <ItemsControl x:Name="prescriptionsPanel" ItemTemplate="{StaticResource PrescriptionTemplate}"/>
                            <TextBlock x:Name="txtNoPrescriptions" Text="No prescriptions yet" FontSize="14" Foreground="#FF6B7280" Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource PageCardStyle}" Padding="22">
                        <StackPanel>
                            <TextBlock Text="Allergies" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,6"/>
                            <TextBlock x:Name="txtAllergyCount" FontSize="17" FontWeight="SemiBold" Foreground="#FF111827" Margin="0,0,0,12"/>
                            <ItemsControl x:Name="allergiesPanel"/>
                            <TextBlock x:Name="txtNoAllergies" Text="No allergies recorded" FontSize="14" Foreground="#FF6B7280" Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource PageCardStyle}" Padding="22">
                        <StackPanel>
                            <TextBlock Text="Chronic Problems" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,6"/>
                            <TextBlock x:Name="txtChronicCount" FontSize="17" FontWeight="SemiBold" Foreground="#FF111827" Margin="0,0,0,12"/>
                            <ItemsControl x:Name="chronicPanel"/>
                            <TextBlock x:Name="txtNoChronic" Text="No chronic problems recorded" FontSize="14" Foreground="#FF6B7280" Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Column="1" Style="{StaticResource PageCardStyle}" Padding="24" Margin="0,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Recent Visits" Style="{StaticResource SectionTitleStyle}" FontSize="28" Margin="0,0,0,18"/>

                <TextBox x:Name="txtVisitSearch" Grid.Row="1" Style="{StaticResource SearchBoxStyle}" Margin="0,0,0,18" TextChanged="txtVisitSearch_TextChanged"/>

                <Grid Grid.Row="2">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="visitsPanel" ItemTemplate="{StaticResource VisitTemplate}"/>
                    </ScrollViewer>
                    <TextBlock x:Name="txtNoVisits" Text="No visits yet" FontSize="14" Foreground="#FF6B7280" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
