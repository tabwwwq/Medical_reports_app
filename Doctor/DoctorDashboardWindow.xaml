<Window x:Class="MedicalReportsApp.DoctorDashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Doctor Dashboard"
        Height="900"
        Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#FFF3F4F6">
    <Window.Resources>
        <Style x:Key="PageCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFF8FAFC"/>
            <Setter Property="BorderBrush" Value="#FFD1D5DB"/>
            <Setter Property="BorderThickness" Value="1.2"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Margin" Value="0,0,0,18"/>
        </Style>

        <Style x:Key="ActionBlueButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="MinWidth" Value="132"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#FF2F6FED"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="MinWidth" Value="90"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#FF111827"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#FFD1D5DB"/>
            <Setter Property="BorderThickness" Value="1.2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SearchBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="56"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF2F6FED"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="16,0,16,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="14,0,14,0" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource PageCardStyle}" Padding="26,22,26,24">
            <StackPanel>
                <DockPanel Margin="0,0,0,18">
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                        <Border x:Name="doctorAvatarBorder" Width="82" Height="82" CornerRadius="41" Background="#FF111827" BorderBrush="#FFCBD5E1" BorderThickness="2" MouseLeftButtonDown="doctorAvatarBorder_MouseLeftButtonDown" Margin="0,0,18,0">
                            <TextBlock x:Name="txtDoctorInitials" Text="DR" Foreground="White" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="txtDoctorName" Text="Doctor" FontSize="30" FontWeight="Bold" Foreground="#FF111827"/>
                        <TextBlock x:Name="txtDoctorInfo" Text="General doctor" FontSize="15" Foreground="#FF6B7280" Margin="0,6,0,0"/>
                            <TextBlock Text="Click avatar to upload profile picture" FontSize="12" Foreground="#FF64748B" Margin="0,6,0,0"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Refresh" Style="{StaticResource GhostButtonStyle}" Margin="0,0,10,0" Click="btnRefresh_Click"/>
                        <Button Content="Logout" Style="{StaticResource GhostButtonStyle}" Click="btnLogout_Click"/>
                    </StackPanel>
                </DockPanel>

                <TextBlock Text="Patients Management" FontSize="24" FontWeight="Bold" Foreground="#FF111827" Margin="0,0,0,16"/>
                <TextBox x:Name="txtSearch" Style="{StaticResource SearchBoxStyle}" TextChanged="txtSearch_TextChanged"/>
                <TextBlock x:Name="txtSearchInfo" FontSize="13" Foreground="#FF6B7280" Margin="0,10,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource PageCardStyle}" Padding="26,24,26,24">
            <StackPanel>
                <TextBlock Text="Recomended Patients" FontSize="22" FontWeight="Bold" Foreground="#FF111827" Margin="0,0,0,18"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="patientsPanel"/>
                </ScrollViewer>
            </StackPanel>
        </Border>
    </Grid>
</Window>
