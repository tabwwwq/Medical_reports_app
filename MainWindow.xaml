<Window x:Class="MedicalReportsApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Account"
        Height="760"
        Width="670"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FFF3F4F6">
    <Window.Resources>
        <Style x:Key="TitleText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF0F172A"/>
        </Style>

        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#FF1E293B"/>
        </Style>

        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="52"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="14,0,14,0"/>
            <Setter Property="Background" Value="#FFF8FAFC"/>
            <Setter Property="BorderBrush" Value="#FFD1D5DB"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="InputPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="Height" Value="52"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="14,0,14,0"/>
            <Setter Property="Background" Value="#FFF8FAFC"/>
            <Setter Property="BorderBrush" Value="#FFD1D5DB"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="58"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#FF2F6FED"/>
            <Setter Property="BorderBrush" Value="#FF2B63D9"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="GreenButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#FF16C246"/>
            <Setter Property="BorderBrush" Value="#FF0EA53A"/>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="52"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#FF111827"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#FFD1D5DB"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Border Width="460"
                Background="White"
                CornerRadius="16"
                BorderBrush="#FFD1D5DB"
                BorderThickness="2"
                Padding="34"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Create Account"
                               Style="{StaticResource TitleText}"
                               FontSize="30"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>

                    <TextBlock Text="Register with email verification"
                               HorizontalAlignment="Center"
                               FontSize="16"
                               Foreground="#FF64748B"
                               Margin="0,0,0,28"/>

                    <TextBlock Text="Email Address *" Style="{StaticResource LabelText}"/>
                    <TextBox x:Name="txtEmail"
                             Style="{StaticResource InputTextBoxStyle}"
                             Margin="0,10,0,18"/>

                    <TextBlock Text="Password *" Style="{StaticResource LabelText}"/>
                    <PasswordBox x:Name="txtPassword"
                                 Style="{StaticResource InputPasswordBoxStyle}"
                                 Margin="0,10,0,6"/>
                    <TextBlock Text="Minimum 6 characters"
                               Foreground="#FF64748B"
                               Margin="0,0,0,18"/>

                    <TextBlock Text="Confirm Password *" Style="{StaticResource LabelText}"/>
                    <PasswordBox x:Name="txtRepeatPassword"
                                 Style="{StaticResource InputPasswordBoxStyle}"
                                 Margin="0,10,0,10"/>

                    <TextBlock x:Name="txtPasswordMessage"
                               Foreground="#FFDC2626"
                               Margin="0,0,0,12"
                               TextWrapping="Wrap"/>

                    <Button x:Name="btnSendCode"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Content="Send Verification Code"
                            Margin="0,10,0,18"
                            Click="btnSendCode_Click"/>

                    <TextBlock x:Name="txtError"
                               Foreground="#FFDC2626"
                               TextWrapping="Wrap"
                               Visibility="Collapsed"
                               Margin="0,0,0,12"/>

                    <Border x:Name="verificationPanel"
                            Visibility="Collapsed"
                            Margin="0,4,0,0">
                        <StackPanel>
                            <Border Background="#FFF0FDF4"
                                    BorderBrush="#FF4ADE80"
                                    BorderThickness="2"
                                    CornerRadius="12"
                                    Padding="16"
                                    Margin="0,0,0,18">
                                <StackPanel>
                                    <TextBlock Text="Verification code sent!"
                                               FontWeight="Bold"
                                               FontSize="18"
                                               Foreground="#FF15803D"/>
                                    <TextBlock x:Name="txtVerificationInfo"
                                               Margin="0,6,0,0"
                                               Foreground="#FF166534"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="Enter Verification Code *" Style="{StaticResource LabelText}"/>
                            <TextBox x:Name="txtCode"
                                     Style="{StaticResource InputTextBoxStyle}"
                                     Margin="0,10,0,6"
                                     HorizontalContentAlignment="Center"
                                     FontSize="26"
                                     MaxLength="6"/>
                            <TextBlock Text="Enter the 6-digit code sent to your email"
                                       HorizontalAlignment="Center"
                                       Foreground="#FF64748B"
                                       Margin="0,0,0,18"/>

                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button x:Name="btnBack"
                                        Grid.Column="0"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Content="Back"
                                        Click="btnBack_Click"/>

                                <Button x:Name="btnVerify"
                                        Grid.Column="2"
                                        Style="{StaticResource GreenButtonStyle}"
                                        Content="Verify &amp; Register"
                                        Click="btnVerify_Click"/>
                            </Grid>

                            <Button x:Name="btnResend"
                                    Content="Resend verification code"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="#FF2563EB"
                                    FontSize="16"
                                    Cursor="Hand"
                                    Click="btnResend_Click"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
